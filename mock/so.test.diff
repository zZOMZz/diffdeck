+        type: "face-show",
+        value: index + 1,
+        p1: suggestion.word,
+      });
+    });
+  }
+
+  // entity 曝光打点
+  if (suggestion.type === "entity") {
+    pendingLogs.push(() => {
+      logService.suggest.log({
+        type: "entity-show",
+        value: index + 1,
+        p1: suggestion.word,
+      });
+    });
+  }
+
+  if (pendingLogs.length > 0 && props.isExpanded) {
+    pendingLogs.forEach((log) => log());
+    pendingLogs.length = 0;
+  }
+};
+
+watch(() => props.isExpanded, (newVal) => {
+  if (newVal) {
+    pendingLogs.forEach((log) => log());
+    pendingLogs.length = 0;
+  }
+}, { immediate: true });
+
+// 右侧preview panel 打点
+const logPreviewPanelClick = (suggestion) => {
+  logService.preview.click({
+    type: "preview-click",
+    p1: suggestion.word,
+  });
+};
+
+const logPreviewPanelShow = (suggestion) => {
+  logService.preview.show({
+    type: "preview-show",
+    p1: suggestion.word,
+  });
+};
 </script>
